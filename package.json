{
  "name": "webauthn-todo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "dev:frontend": "vite",
    "migrate": "node scripts/migrate.mjs",
    "build:frontend": "vite build",
    "build": "node scripts/migrate.mjs && vite build",
    "deploy": "node scripts/migrate.mjs && vite build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "type-check": "tsc --noEmit",
    "lint": "vp lint",
    "format": "vp format",
    "check": "vp check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@lexical/history": "^0.42.0",
    "@lexical/list": "^0.42.0",
    "@lexical/rich-text": "^0.42.0",
    "@libsql/client": "^0.17.2",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.1.1",
    "hono": "^4.12.14",
    "lexical": "^0.42.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250401.0",
    "@playwright/test": "^1.59.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.5",
    "vite-plus": "^0.1.17",
    "vitest": "^4.1.2",
    "wrangler": "^4.12.0"
  }
}
