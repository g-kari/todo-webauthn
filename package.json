{
  "name": "webauthn-todo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "dev:frontend": "vite",
    "build": "vite build && wrangler deploy --dry-run",
    "build:frontend": "vite build",
    "deploy": "vite build && wrangler deploy",
    "db:create": "wrangler d1 create webauthn-todo-db",
    "db:migrate:local": "wrangler d1 migrations apply webauthn-todo-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply webauthn-todo-db --remote",
    "cf-typegen": "wrangler types",
    "type-check": "tsc --noEmit",
    "lint": "vp lint",
    "format": "vp format",
    "check": "vp check"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.1.1",
    "hono": "^4.7.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250401.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.3",
    "vite-plus": "^0.1.15",
    "wrangler": "^4.12.0"
  }
}
